# Environment Variables for Carbon Intelligence Platform
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Google Cloud ─────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id

# ── Google Gemini AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=1024
GEMINI_TEMPERATURE=0.1

# ── Google OAuth 2.0 (Phase 2 — Gmail API) ───────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── PaddleOCR Sidecar ────────────────────────────────────────────────────────
PADDLE_OCR_URL=http://localhost:8001
PADDLE_OCR_TIMEOUT=30
OCR_PROVIDER=paddle

# ── Firestore Collection Names (optional — defaults shown) ───────────────────
FIRESTORE_ACTIVITIES_COLLECTION=activities
FIRESTORE_RAW_DOCS_COLLECTION=raw_documents
FIRESTORE_CARBON_COLLECTION=carbon_assessments

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
