# ============================================================
# Carbon Intelligence Platform — .gitignore
# ============================================================

# --------------------------------------------------
# OS
# --------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# --------------------------------------------------
# IDE / Editor
# --------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
.vscode/
*.code-workspace

# --------------------------------------------------
# Environment & Secrets
# --------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
service-account*.json
*-service-account.json
application-secret*.yml

# --------------------------------------------------
# Logs
# --------------------------------------------------
logs/
*.log

# --------------------------------------------------
# Java / Spring Boot
# --------------------------------------------------
target/
*.class
*.jar
*.war
*.ear
*.nar
.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties
spring-boot-devtools.properties

# --------------------------------------------------
# Node / Frontend
# --------------------------------------------------
node_modules/
dist/
.vite/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --------------------------------------------------
# Python
# --------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
venv/
.venv/
env/
ENV/
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --------------------------------------------------
# PaddleOCR Models
# --------------------------------------------------
*.pdparams
*.pdmodel
*.pdiparams

# --------------------------------------------------
# Android / Gradle
# --------------------------------------------------
.gradle/
build/
local.properties
captures/
.cxx/
*.apk
*.aab

# Android generated files
android/*.db
android/*.db-wal
android/*.db-shm
android/*.db-journal
android/*.txt
android/*.xml
!android/app/src/main/res/xml/*.xml
!android/app/src/debug/res/xml/*.xml

# Android signing (NEVER commit keystores)
*.jks
*.keystore
keystore.properties

# --------------------------------------------------
# Test Outputs
# --------------------------------------------------
surefire-reports/
*.exec

# --------------------------------------------------
# Build Artifacts
# --------------------------------------------------
*.tar.gz
*.zip
