# ── Server configuration ──────────────────────────────────────────────────────
PORT=8080
SPRING_PROFILES_ACTIVE=prod

# ── Google Cloud Platform ─────────────────────────────────────────────────────
# Required for Firestore client unless using the emulator
GCP_PROJECT_ID=your-gcp-project-id
# Path to service account JSON file for local execution without gcloud credentials
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/keyfile.json

# ── AI Services ───────────────────────────────────────────────────────────────
# Groq API Key for receipt processing and AI coaching
GROQ_API_KEY=your-groq-api-key
GROQ_RECEIPT_MODEL=openai/gpt-oss-20b
GROQ_COACH_MODEL=llama-3.3-70b-versatile

# ── OCR Configuration ─────────────────────────────────────────────────────────
OCR_PROVIDER=paddle
PADDLE_OCR_URL=http://localhost:8001
PADDLE_OCR_TIMEOUT=30

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Google OAuth 2.0 (Optional — Phase 2) ──────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Local Emulators (Optional) ────────────────────────────────────────────────
# FIRESTORE_EMULATOR_HOST=localhost:8089
