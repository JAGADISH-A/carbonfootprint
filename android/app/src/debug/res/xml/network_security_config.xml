<?xml version="1.0" encoding="utf-8"?>
<!--
    DEBUG ONLY — this file lives in src/debug/res/xml/ and is NEVER
    included in release builds.

    Permits cleartext HTTP traffic to local development addresses only:
      • 127.0.0.1  — used via "adb reverse tcp:8080 tcp:8080"
      • localhost  — hostname alias for the same loopback address
      • 10.0.2.2   — Android emulator alias for the host machine

    All other traffic still requires HTTPS.
-->
<network-security-config>

    <!-- Allow cleartext to local dev hosts only -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!-- Everything else: HTTPS only, trust system CAs -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>
